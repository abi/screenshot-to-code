{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "dev",
        "--port",
        "5199",
        "--strictPort"
      ],
      "port": 5199,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "poetry",
      "runtimeArgs": [
        "run",
        "uvicorn",
        "main:app",
        "--port",
        "7001"
      ],
      "port": 7001,
      "cwd": "backend"
    },
    {
      "name": "hosted-frontend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["dev", "--mode", "prod", "--port", "5199", "--strictPort"],
      "port": 5199,
      "autoPort": false,
      "cwd": "frontend"
    }
  ]
}
